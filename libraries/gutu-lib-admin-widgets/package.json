{
  "name": "gutu-lib-admin-widgets",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun --cwd framework/libraries/admin-widgets run build",
    "typecheck": "bun --cwd framework/libraries/admin-widgets run typecheck",
    "lint": "bun --cwd framework/libraries/admin-widgets run lint",
    "test": "bun --cwd framework/libraries/admin-widgets run test",
    "test:unit": "bun --cwd framework/libraries/admin-widgets run test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
