{
  "name": "gutu-lib-contracts",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun --cwd framework/libraries/contracts run build",
    "typecheck": "bun --cwd framework/libraries/contracts run typecheck",
    "lint": "bun --cwd framework/libraries/contracts run lint",
    "test": "bun --cwd framework/libraries/contracts run test",
    "test:contracts": "bun --cwd framework/libraries/contracts run test:contracts",
    "test:unit": "bun --cwd framework/libraries/contracts run test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
