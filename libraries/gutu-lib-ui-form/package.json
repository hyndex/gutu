{
  "name": "gutu-lib-ui-form",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun --cwd framework/libraries/ui-form run build",
    "typecheck": "bun --cwd framework/libraries/ui-form run typecheck",
    "lint": "bun --cwd framework/libraries/ui-form run lint",
    "test": "bun --cwd framework/libraries/ui-form run test",
    "test:unit": "bun --cwd framework/libraries/ui-form run test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
