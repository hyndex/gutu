# Copy to `.env` (alongside docker-compose.yml) before bringing the stack up.
# Real values must NEVER be committed.

# Stalwart admin password — used to log into the management UI at
# https://mail.<your-domain>/admin and to issue API tokens for the
# Gutu admin panel's "Self-hosted" settings page.
STALWART_ADMIN_PASSWORD=change-me-please

# Postgres credentials. The DB itself is created on first boot.
POSTGRES_PASSWORD=stalwart-pg-strong-password

# MinIO root credentials — these own the `mail-blobs` bucket. Rotate
# regularly. In production, use a per-bucket access key with limited
# scope rather than the root user.
MINIO_ROOT_USER=stalwart
MINIO_ROOT_PASSWORD=stalwart-minio-strong-password
