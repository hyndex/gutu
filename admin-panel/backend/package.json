{
  "name": "@gutu/admin-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Real REST backend for the Gutu admin panel. Bun + Hono + SQLite.",
  "scripts": {
    "dev": "bun run --hot src/main.ts",
    "start": "bun run src/main.ts",
    "seed": "bun run src/seed/run.ts",
    "reset": "rm -f data.db && bun run seed",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.645.0",
    "@aws-sdk/s3-request-presigner": "^3.645.0",
    "hono": "^4.6.14",
    "lib0": "^0.2.117",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.3"
  }
}
